# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/resume_analyser

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-at-least-32-chars
JWT_REFRESH_SECRET=change-me-at-least-32-chars

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: http://localhost:3000/api/auth/google/callback (dev)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=https://your-server.onrender.com/api/auth/google/callback  # production

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=           # Required for Upstash / managed Redis
# REDIS_TLS=true            # Set to "true" for Upstash TLS URLs

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Cloudinary (optional — file uploads stored in memory if omitted) ──────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Pinecone (optional — semantic match skipped if omitted) ──────────────────
# PINECONE_API_KEY=
# PINECONE_INDEX=resume-analyser

# ── App ──────────────────────────────────────────────────────────────────────
PORT=3000
CLIENT_URL=http://localhost:5173      # Set to your Vercel URL in production
NODE_ENV=development
